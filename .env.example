# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# OpenAI Integration (if using Replit AI Integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=your_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=your_base_url_here

# Optional: For local OpenAI development (if not using Replit)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Environment
NODE_ENV=development
PORT=5000
